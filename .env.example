# Hugging Face Token for accessing gated models
# Get your token from: https://huggingface.co/settings/tokens
# Required for accessing gated models like FLUX.1-dev
HF_TOKEN=your_hugging_face_token_here

# Model Selection
# Options: stable-diffusion (default) or flux
MODEL_TYPE=stable-diffusion

# Multi-GPU Configuration
# Options: balanced (default), sequential, none
# - balanced: Distribute evenly across all available GPUs (recommended)
# - sequential: Use GPUs sequentially (0, then 1, etc.)
# - none: Use single GPU (disables multi-GPU)
# Note: "auto" is not supported, use "balanced" instead
DEVICE_MAP=balanced

# Quantization (for FLUX model only)
# Options: 8bit (default), 4bit, none
# - 8bit: Reduces memory by ~2x with minimal quality loss (recommended)
# - 4bit: Reduces memory by ~4x with more quality loss
# - none: Full precision (no quantization)
# Only applies to FLUX model on CUDA GPUs
QUANTIZATION=8bit

# Maximum Memory Per GPU (Optional)
# Format: "GPU_ID:MEMORY_IN_GB"
# Example: "0:10,1:10" limits GPU 0 and 1 to 10GB each
# Leave empty to let accelerate manage automatically
# MAX_MEMORY=0:10,1:10
MAX_MEMORY=
